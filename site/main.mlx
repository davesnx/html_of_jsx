let syntax_toggle () =
  <div class_="syntax-toggle" role=`group aria_label="Code syntax">
    <button type_=`button dataDocSyntax="reason" aria_label="Reason syntax">
      <img class_="syntax-toggle__icon" src="assets/reason.svg" alt="" />
      <span class_="syntax-toggle__label">(JSX.string "Reason")</span>
    </button>
    <button type_=`button dataDocSyntax="mlx" aria_label="mlx syntax">
      <img class_="syntax-toggle__icon" src="assets/ocaml.svg" alt="" />
      <span class_="syntax-toggle__label">(JSX.string "mlx")</span>
    </button>
  </div>

let find_page_by_source_name pages source_name =
  List.find_opt (fun page -> page.source_name = source_name) pages

let sidebar_link ~href ~label ~is_active () =
  if is_active then
    <li>
      <a
        class_="doc-sidebar__link doc-sidebar__link--active"
        aria_current=`page
        href>
        <span class_="doc-sidebar__label">(JSX.string label)</span>
      </a>
    </li>
  else
    <li>
      <a class_="doc-sidebar__link" href>
        <span class_="doc-sidebar__label">(JSX.string label)</span>
      </a>
    </li>

(* JSX.md gets pinned to the top of the API list. The remaining pages sort by
   a key that keeps a parent module immediately before its sub-modules:
   "Htmx" < "Htmx.Extensions" < "Htmx.Extensions.SSE" < "Ppx".
   We achieve this by replacing '-' with '.' in the source name (matching the
   label conversion) and sorting case-insensitively. '.' (0x2e) sorts after
   alphabetic chars, so a parent always precedes its dotted children. *)
let api_sort_key source_name =
  let stem = Filename.remove_extension source_name in
  let dotted =
    String.map
      (fun c ->
        if c = '-' then
          '.'
        else
          c
      )
      stem
  in
  String.lowercase_ascii dotted

let api_pages_sorted pages =
  let api_pages = List.filter (fun p -> not (is_guide_page p)) pages in
  let pinned_first, others =
    List.partition (fun p -> p.source_name = "JSX.md") api_pages
  in
  let sorted_others =
    List.sort
      (fun a b ->
        String.compare (api_sort_key a.source_name) (api_sort_key b.source_name)
      )
      others
  in
  pinned_first @ sorted_others

let sidebar ~pages ~active_output () =
  let guide_items =
    guide_order
    |> List.filter_map (fun source_name ->
        if source_name = "index.md" then
          None
        else
          match find_page_by_source_name pages source_name with
          | Some page ->
              let label =
                sidebar_label_for ~source_name:page.source_name
                  ~title:page.title
              in
              Some
                (sidebar_link ~href:page.output_name ~label
                   ~is_active:(page.output_name = active_output)
                   ()
                )
          | None ->
              None
    )
  in
  let api_items =
    api_pages_sorted pages
    |> List.map (fun page ->
        let label =
          sidebar_label_for ~source_name:page.source_name ~title:page.title
        in
        sidebar_link ~href:page.output_name ~label
          ~is_active:(page.output_name = active_output)
          ()
    )
  in
  <aside class_="doc-sidebar" id="doc-sidebar" aria_label="Documentation">
    <div class_="doc-sidebar__inner">
      <div class_="doc-sidebar__group">
        <h2 class_="doc-sidebar__heading">(JSX.string "Guides")</h2>
        <ul class_="doc-sidebar__list">(JSX.list guide_items)</ul>
      </div>
      <div class_="doc-sidebar__group">
        <h2 class_="doc-sidebar__heading">(JSX.string "API")</h2>
        <ul class_="doc-sidebar__list">(JSX.list api_items)</ul>
      </div>
    </div>
  </aside>

let breadcrumb_separator () =
  <span class_="doc-breadcrumb__sep" aria_hidden=true>(JSX.string "/")</span>

let breadcrumbs ~current () =
  if current.source_name = "index.md" then
    JSX.null
  else
    let section_label =
      if is_guide_page current then
        "Guides"
      else
        "API"
    in
    let page_label =
      sidebar_label_for ~source_name:current.source_name ~title:current.title
    in
    <nav class_="doc-breadcrumb" aria_label="Breadcrumb">
      <ol class_="doc-breadcrumb__list">
        <li class_="doc-breadcrumb__item doc-breadcrumb__item--section">
          (JSX.string section_label)
        </li>
        <li class_="doc-breadcrumb__sep-item"><breadcrumb_separator /></li>
        <li
          class_="doc-breadcrumb__item doc-breadcrumb__item--current"
          aria_current=`page>
          (JSX.string page_label)
        </li>
      </ol>
    </nav>

let brand_logo () =
  <a class_="site-brand" href="index.html">
    <span
      class_="site-brand__bracket site-brand__bracket--open" aria_hidden=true>
      (JSX.string "<")
    </span>
    <span class_="site-brand__name">(JSX.string "html_of_jsx")</span>
    <span
      class_="site-brand__bracket site-brand__bracket--close" aria_hidden=true>
      (JSX.string "/>")
    </span>
  </a>

let version_chip ~version () =
  <a
    class_="site-version"
    href="https://opam.ocaml.org/packages/html_of_jsx/"
    target=`_blank
    rel="noopener noreferrer"
    title=("View html_of_jsx " ^ version ^ " on opam")
    aria_label=("View html_of_jsx " ^ version ^ " on opam")>
    <span class_="site-version__label">(JSX.string ("v" ^ version))</span>
  </a>

let hamburger_button () =
  <label
    class_="nav-hamburger"
    for_="nav-toggle"
    aria_label="Toggle navigation"
    title="Toggle navigation">
    <span class_="nav-hamburger__bar" aria_hidden=true />
    <span class_="nav-hamburger__bar" aria_hidden=true />
    <span class_="nav-hamburger__bar" aria_hidden=true />
  </label>

let skip_link () =
  <a class_="skip-link" href="#main-content">(JSX.string "Skip to content")</a>

let page ~pages ~current () =
  let is_api_page = not (is_guide_page current) in
  let article_html = markdown_body pages current.markdown in
  let article_class =
    if is_api_page then
      "doc-prose"
    else
      "doc-prose doc-prose--guide"
  in
  let site_title = "html_of_jsx documentation" in
  let page_title = current.title ^ " - " ^ site_title in
  <html lang="en" dataDocSyntax="reason">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <title>(JSX.string page_title)</title>
      <meta name="description" content=site_title />
      <link
        rel="preload"
        as_="font"
        type_="font/woff2"
        href="assets/ibm-plex-mono-400.woff2"
        crossorigin="anonymous"
      />
      <link
        rel="preload"
        as_="font"
        type_="font/woff2"
        href="assets/ibm-plex-mono-600.woff2"
        crossorigin="anonymous"
      />
      <link
        rel="preload"
        as_="font"
        type_="font/woff2"
        href="assets/spline-sans-700.woff2"
        crossorigin="anonymous"
      />
      <script>
        (JSX.unsafe
           {|
(function () {
  var root = document.documentElement;
  try {
    var themeKey = "html_of_jsx.docs.theme";
    var theme = localStorage.getItem(themeKey);
    var resolvedTheme =
      theme === "light" || theme === "dark"
        ? theme
        : window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
    root.setAttribute("data-doc-theme", resolvedTheme);
  } catch (_error) {}
  try {
    var syntaxKey = "html_of_jsx.docs.syntax";
    var normalize = function (value) {
      return value === "mlx" || value === "reason" ? value : null;
    };
    var search = window.location.search;
    var queryParam = null;
    if (search && search.indexOf("syntax=") !== -1) {
      try {
        queryParam = normalize(new URLSearchParams(search).get("syntax"));
      } catch (_error) {}
    }
    var stored = null;
    try { stored = normalize(localStorage.getItem(syntaxKey)); } catch (_error) {}
    if (queryParam && queryParam !== stored) {
      try { localStorage.setItem(syntaxKey, queryParam); } catch (_error) {}
    }
    var resolvedSyntax = queryParam || stored || "reason";
    root.setAttribute("data-doc-syntax", resolvedSyntax);
  } catch (_error) {
    root.setAttribute("data-doc-syntax", "reason");
  }
  root.setAttribute("data-syntax-ready", "");
})();
|}
        )
      </script>
      <link rel="stylesheet" href="assets/fonts.css" />
      <style>(JSX.unsafe code_theme_dark_css)</style>
      <link rel="stylesheet" href="assets/index.css" />
      <script src="assets/index.js" defer=true />
    </head>
    <body>
      <skip_link />
      <input
        id="nav-toggle" class_="nav-toggle" type_=`checkbox aria_hidden=true
      />
      <label class_="nav-backdrop" for_="nav-toggle" aria_hidden=true />
      <header class_="site-header">
        <div class_="site-header__inner">
          <div class_="site-header__leading">
            <hamburger_button />
            <brand_logo />
            <a
              target=`_blank
              rel="noopener noreferrer"
              class_="site-brand__github"
              href="https://github.com/davesnx/html_of_jsx"
              aria_label="Open html_of_jsx GitHub repository"
              title="GitHub repository">
              <github_icon />
            </a>
            <version_chip version=site_version />
          </div>
          <div class_="site-controls">
            <syntax_toggle />
            <button
              class_="theme-toggle"
              type_=`button
              dataDocThemeToggle=""
              aria_label="Toggle color theme"
              title="Toggle color theme">
              <span class_="theme-toggle__sun" aria_hidden=true>"✹"</span>
              <span class_="theme-toggle__moon" aria_hidden=true>"⏾"</span>
            </button>
          </div>
        </div>
      </header>
      <div class_="doc-shell">
        <sidebar pages active_output=current.output_name />
        <main id="main-content" class_="doc-main">
          <breadcrumbs current />
          <article class_=article_class>(JSX.unsafe article_html)</article>
        </main>
      </div>
    </body>
  </html>

let load_pages source_files =
  let open Eff in
  let rec collect acc = function
    | [] ->
        return (Stdlib.List.rev acc)
    | source :: rest ->
        let* markdown = read_file ~snapshot:true ~on:`Source source in
        collect (page_of_markdown source markdown :: acc) rest
  in
  let+ pages = collect [] source_files in
  Stdlib.List.sort compare_pages pages

let cache_file = Path.rel [ "docs"; "_cache" ]

let copy_assets cache =
  let open Eff in
  let* files =
    read_directory ~on:`Source ~only:`Files
      ~where:(Path.one_of_extensions [ "css"; "js"; "svg"; "woff2" ])
      assets_dir
  in
  let rec copy_all cache = function
    | [] ->
        return cache
    | source :: rest ->
        let* cache = Action.copy_file ~into:target_assets_dir source cache in
        copy_all cache rest
  in
  copy_all cache files

let write_pages pages source_files cache =
  let open Eff in
  let deps = Deps.from_list source_files in
  let rec write_all cache = function
    | [] ->
        return cache
    | current :: rest ->
        let target = Path.(target_dir / current.output_name) in
        let task =
          Task.make deps (fun () ->
              Eff.return (JSX.render <page pages current />)
          )
        in
        let* cache = Action.Static.write_file target task cache in
        write_all cache rest
  in
  write_all cache pages

let process_all () =
  let open Eff in
  let* source_files =
    read_directory ~on:`Source ~only:`Files ~where:(Path.has_extension "md")
      source_dir
  in
  let source_files =
    source_files
    |> Stdlib.List.sort (fun left right ->
        String.compare (basename_exn left) (basename_exn right)
    )
  in
  if source_files = [] then
    invalid_arg "No markdown files found. Run `dune build @doc-markdown` first.";
  let* pages = load_pages source_files in
  Action.with_cache ~on:`Source cache_file (fun cache ->
      let* cache = write_pages pages source_files cache in
      copy_assets cache
  )

type cli_mode = Build | Serve of int

let usage = "Usage: main.exe [serve [--port PORT]]"

let parse_port value =
  match int_of_string_opt value with
  | Some port when port > 0 && port < 65536 ->
      Some port
  | _ ->
      None

let mode_from_cli () =
  let args = match Array.to_list Sys.argv with [] -> [] | _ :: rest -> rest in
  match args with
  | [ "build" ] ->
      Some Build
  | [ "serve" ] ->
      Some (Serve 8080)
  | [ "serve"; "--port"; value ] ->
      Option.map (fun port -> Serve port) (parse_port value)
  | _ ->
      None

let () =
  match mode_from_cli () with
  | Some Build ->
      Yocaml_unix.run ~level:`Info process_all
  | Some (Serve port) ->
      Yocaml_unix.serve ~level:`Info ~target:target_dir ~port process_all
  | None ->
      prerr_endline usage;
      exit 2
