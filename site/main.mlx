open Yocaml

type syntax = Reason | Mlx

type page = {
  source_name : string;
  output_name : string;
  title : string;
  markdown : string;
}

let source_dir =
  Path.rel [ "_build"; "default"; "_doc"; "_markdown"; "html_of_jsx" ]
let assets_dir = Path.rel [ "site"; "assets" ]
let target_dir = Path.rel [ "docs"; "_site" ]
let target_assets_dir = Path.(target_dir / "assets")

let changes_path = "CHANGES.md"

(* A version heading in CHANGES.md looks like "## 0.0.9". We extract the first
   such heading (the most recent release). The token after "## " is the
   version when it starts with a digit; this skips non-version sub-headings if
   any are introduced later. Whitespace and trailing CRs are trimmed. *)
let extract_version_from_changes content =
  let lines = String.split_on_char '\n' content in
  let starts_with_digit s =
    String.length s > 0 && s.[0] >= '0' && s.[0] <= '9'
  in
  let rec find = function
    | [] ->
        None
    | line :: rest ->
        let line = String.trim line in
        let prefix = "## " in
        let plen = String.length prefix in
        if String.length line > plen && String.sub line 0 plen = prefix then
          let token =
            String.trim (String.sub line plen (String.length line - plen))
          in
          if starts_with_digit token then
            Some token
          else
            find rest
        else
          find rest
  in
  find lines

let read_file_opt path =
  try
    let ic = open_in path in
    let len = in_channel_length ic in
    let buf = Bytes.create len in
    really_input ic buf 0 len;
    close_in ic;
    Some (Bytes.unsafe_to_string buf)
  with _ -> None

let resolve_version () =
  match read_file_opt changes_path with
  | Some content -> (
      match extract_version_from_changes content with
      | Some v ->
          v
      | None ->
          "dev"
    )
  | None ->
      "dev"

let site_version = resolve_version ()

let guide_order =
  [
    "index.md";
    "getting-started.md";
    "core.md";
    "ppx.md";
    "how-ppx-works.md";
    "dream.md";
    "HTMX-mode.md";
    "React-compatibility.md";
  ]

(* Display labels in the sidebar override the H1-derived page title for
   specific pages. Keep the project's voice: lowercase ppx, short names. *)
let sidebar_label_overrides =
  [
    ("ppx.md", "ppx");
    ("dream.md", "Dream");
    ("HTMX-mode.md", "htmx");
    ("React-compatibility.md", "React compat");
  ]

(* For API pages, derive the label from the source filename so the dotted
   module path is preserved (Htmx-Extensions-SSE.md -> "Htmx.Extensions.SSE").
   This keeps the parent/child relationship visible in a flat list. *)
let label_from_api_source_name source_name =
  let stem = Filename.remove_extension source_name in
  String.map
    (fun c ->
      if c = '-' then
        '.'
      else
        c
    )
    stem

let is_api_source_name source_name = not (List.mem source_name guide_order)

let sidebar_label_for ~source_name ~title =
  match List.assoc_opt source_name sidebar_label_overrides with
  | Some override ->
      override
  | None when is_api_source_name source_name ->
      label_from_api_source_name source_name
  | None ->
      (* For guides, fall back to the H1 title as extracted from the file. *)
      title

let highlighter =
  Ochre.create_from_json
    ~grammars:
      [
        ("reason", Tm_grammars.reason);
        ("mlx", Tm_grammars.mlx);
        ("dune", Tm_grammars.dune);
        ("bash", Tm_grammars.shellscript);
        ("ocaml", Tm_grammars.ocaml);
      ]
    ()

let basename_exn path =
  match Path.basename path with
  | Some name ->
      name
  | None ->
      invalid_arg ("Expected a basename for path: " ^ Path.to_string path)

let output_name_of_source_name source_name =
  let stem = Filename.remove_extension source_name in
  if stem = "index" then
    "index.html"
  else
    stem ^ ".html"

let replace_all ~pattern ~with_ text =
  if pattern = "" then
    text
  else
    let pattern_length = String.length pattern in
    let text_length = String.length text in
    let buffer = Buffer.create text_length in
    let rec loop index =
      if index >= text_length then
        ()
      else if
        index <= text_length - pattern_length
        && String.sub text index pattern_length = pattern
      then (
        Buffer.add_string buffer with_;
        loop (index + pattern_length)
      ) else (
        Buffer.add_char buffer text.[index];
        loop (index + 1)
      )
    in
    loop 0;
    Buffer.contents buffer

let first_word text =
  let trimmed = String.trim text in
  let length = String.length trimmed in
  let rec find index =
    if index >= length then
      length
    else
      match trimmed.[index] with
      | ' ' | '\t' | '\n' | '\r' ->
          index
      | _ ->
          find (index + 1)
  in
  if length = 0 then
    ""
  else
    String.sub trimmed 0 (find 0)

let normalize_code_label label = first_word label |> String.lowercase_ascii

type language_info = {
  syntax : syntax option;
  highlight_lang : string option;
  badge : string;
}

let language_of_label label =
  match normalize_code_label label with
  | "reason" | "reasonml" ->
      Some
        {
          syntax = Some Reason;
          highlight_lang = Some "reason";
          badge = "Reason";
        }
  | "mlx" ->
      Some { syntax = Some Mlx; highlight_lang = Some "mlx"; badge = "mlx" }
  | "dune" ->
      Some { syntax = None; highlight_lang = Some "dune"; badge = "dune" }
  | "bash" | "sh" | "shell" | "shellscript" ->
      Some { syntax = None; highlight_lang = Some "bash"; badge = "bash" }
  | "ocaml" ->
      Some { syntax = None; highlight_lang = Some "ocaml"; badge = "ocaml" }
  | "" ->
      None
  | other ->
      Some { syntax = None; highlight_lang = None; badge = other }

let syntax_of_label label =
  Option.bind (language_of_label label) (fun info -> info.syntax)

let trim_trailing_newlines text =
  let rec find_last_non_newline index =
    if index < 0 then
      -1
    else
      match text.[index] with
      | '\n' | '\r' ->
          find_last_non_newline (index - 1)
      | _ ->
          index
  in
  let last_index = find_last_non_newline (String.length text - 1) in
  if last_index < 0 then
    ""
  else
    String.sub text 0 (last_index + 1)

let make_code_theme ~name ~fg ~bg ~comment ~string ~number ~keyword ~fn ~typ =
  Ochre.Theme.make ~name
    ~colors:[ ("editor.foreground", fg); ("editor.background", bg) ]
    ~token_colors:
      [
        Ochre.Theme.rule ~scope:[ "comment" ] ~foreground:comment ();
        Ochre.Theme.rule ~scope:[ "string" ] ~foreground:string ();
        Ochre.Theme.rule ~scope:[ "constant.numeric" ] ~foreground:number ();
        Ochre.Theme.rule ~scope:[ "keyword" ] ~foreground:keyword ();
        Ochre.Theme.rule
          ~scope:[ "entity.name.function"; "support.function" ]
          ~foreground:fn ();
        Ochre.Theme.rule
          ~scope:[ "entity.name.type"; "support.type"; "storage.type" ]
          ~foreground:typ ();
      ]
    ()

let code_theme_gruvbox_light =
  make_code_theme ~name:"gruvbox-light" ~fg:"#3C3836" ~bg:"#FEF6ED"
    ~comment:"#928374" ~string:"#79740E" ~number:"#8F3F71" ~keyword:"#9D0006"
    ~fn:"#B57614" ~typ:"#076678"

let code_theme_gruvbox =
  make_code_theme ~name:"gruvbox" ~fg:"#EBDBB2" ~bg:"#2C241E" ~comment:"#928374"
    ~string:"#B8BB26" ~number:"#D3869B" ~keyword:"#FB4934" ~fn:"#FABD2F"
    ~typ:"#8EC07C"

let code_theme_dark_css =
  {|
.ochre,
.ochre span {
  color: var(--ochre);
  background-color: var(--ochre-bg);
}

:root[data-doc-theme="dark"] .ochre,
:root[data-doc-theme="dark"] .ochre span {
  --ochre: var(--ochre-dark);
  --ochre-bg: var(--ochre-dark-bg);
  --ochre-font-style: var(--ochre-dark-font-style);
  --ochre-font-weight: var(--ochre-dark-font-weight);
  --ochre-text-decoration: var(--ochre-dark-text-decoration);
}

:root[data-doc-theme="light"] .ochre,
:root[data-doc-theme="light"] .ochre span {
  --ochre: var(--ochre);
  --ochre-bg: var(--ochre-bg);
  --ochre-font-style: var(--ochre-font-style);
  --ochre-font-weight: var(--ochre-font-weight);
  --ochre-text-decoration: var(--ochre-text-decoration);
}
|}

let highlighted_code ~highlight_lang ~code () =
  let plain_code () =
    <pre class_="doc-code__pre">
      <code class_="doc-code__code">(JSX.unsafe code)</code>
    </pre>
  in
  match highlight_lang with
  | None ->
      <plain_code />
  | Some language -> (
      let ochre_options =
        Ochre.Html_options.make ~pre_class:"doc-code__pre"
          ~code_class:"doc-code__code" ()
      in
      try
        Ochre.to_html highlighter ~options:ochre_options
          ~theme:code_theme_gruvbox_light
          ~extra_themes:[ ("dark", code_theme_gruvbox) ]
          ~lang:language code
        |> JSX.unsafe
      with exn ->
        Printf.eprintf "Warning: highlighting failed for %s: %s\n" language
          (Printexc.to_string exn);
        <plain_code />
    )

let string_of_syntax = function Reason -> "reason" | Mlx -> "mlx"

let code_pair_tabs () =
  <div class_="doc-code-pair__tabs" role=`group aria_label="Code syntax">
    <button
      type_=`button
      class_="doc-code-pair__tab"
      dataDocSyntax="reason"
      aria_label="Show Reason syntax">
      <img class_="doc-code-pair__icon" src="assets/reason.svg" alt="" />
      <span class_="doc-code-pair__label">(JSX.string "Reason")</span>
    </button>
    <button
      type_=`button
      class_="doc-code-pair__tab"
      dataDocSyntax="mlx"
      aria_label="Show mlx syntax">
      <img class_="doc-code-pair__icon" src="assets/ocaml.svg" alt="" />
      <span class_="doc-code-pair__label">(JSX.string "mlx")</span>
    </button>
  </div>

let copy_button () =
  <button class_="doc-code__copy" type_=`button dataDocCopy="">
    <svg class_="doc-code__copy-icon" viewBox="0 0 24 24" aria_hidden=true>
      <rect x="9" y="9" width="10" height="10" rx="2" />
      <rect x="5" y="5" width="10" height="10" rx="2" />
    </svg>
    <span class_="doc-code__copy-label">(JSX.string "Copy")</span>
  </button>

let code_caption ~badge () =
  <figcaption class_="doc-code__meta">
    ( match badge with
    | Some language ->
        <span class_="doc-code__lang">(JSX.string language)</span>
    | None ->
        JSX.null
    )
    <copy_button />
  </figcaption>

(* For paired Reason/mlx code figures, the figcaption hosts the syntax tabs on
   the left and the Copy button on the right — replacing the language badge. *)
let code_caption_pair () =
  <figcaption class_="doc-code__meta doc-code__meta--pair">
    <code_pair_tabs /> <copy_button />
  </figcaption>

let code_figure ?syntax ~label ~code () =
  let lang_info = language_of_label label in
  let highlight_lang = Option.bind lang_info (fun i -> i.highlight_lang) in
  let badge = Option.map (fun i -> i.badge) lang_info in
  let normalized_code = trim_trailing_newlines code in
  let highlighted = <highlighted_code highlight_lang code=normalized_code /> in
  match syntax with
  | None ->
      <figure class_="doc-code"><code_caption badge /> highlighted</figure>
  | Some value ->
      <figure class_="doc-code" dataSyntax=(string_of_syntax value)>
        <code_caption_pair /> highlighted
      </figure>

let syntax_pair ~reason_label ~reason_code ~mlx_label ~mlx_code () =
  <div class_="doc-code-pair">
    <code_figure syntax=Reason label=reason_label code=reason_code />
    <code_figure syntax=Mlx label=mlx_label code=mlx_code />
  </div>

let rec inline_to_text = function
  | Omd.Concat (_, items) ->
      items |> List.map inline_to_text |> String.concat ""
  | Omd.Text (_, text) ->
      text
  | Omd.Emph (_, value) | Omd.Strong (_, value) ->
      inline_to_text value
  | Omd.Code (_, code) ->
      code
  | Omd.Hard_break _ | Omd.Soft_break _ ->
      " "
  | Omd.Link (_, link) | Omd.Image (_, link) ->
      inline_to_text link.label
  | Omd.Html (_, text) ->
      text

let humanize_source_name source_name =
  source_name |> Filename.remove_extension
  |> String.map (fun character ->
      if character = '-' then
        ' '
      else
        character
  )

let extract_title source_name markdown =
  let rec find_heading = function
    | Omd.Heading (_, _, label) :: _ ->
        inline_to_text label |> String.trim
    | _ :: rest ->
        find_heading rest
    | [] ->
        humanize_source_name source_name
  in
  find_heading (Omd.of_string markdown)

let rec index_of value index = function
  | [] ->
      None
  | candidate :: rest ->
      if candidate = value then
        Some index
      else
        index_of value (index + 1) rest

let page_rank source_name =
  match index_of source_name 0 guide_order with
  | Some rank ->
      rank
  | None ->
      1000

let is_guide_page page = page_rank page.source_name < 1000

let compare_pages left right =
  let rank_comparison =
    Int.compare (page_rank left.source_name) (page_rank right.source_name)
  in
  if rank_comparison <> 0 then
    rank_comparison
  else
    String.compare
      (String.lowercase_ascii left.source_name)
      (String.lowercase_ascii right.source_name)

let page_of_markdown source markdown =
  let source_name = basename_exn source in
  {
    source_name;
    output_name = output_name_of_source_name source_name;
    title = extract_title source_name markdown;
    markdown;
  }

let links_map pages =
  pages
  |> List.fold_left
       (fun acc page ->
         ("./" ^ page.source_name, page.output_name)
         :: (page.source_name, page.output_name)
         :: acc
       )
       []

let rewrite_html_links pages html =
  links_map pages
  |> List.fold_left
       (fun acc (source_name, output_name) ->
         acc
         |> replace_all
              ~pattern:("href=\"" ^ source_name ^ "\"")
              ~with_:("href=\"" ^ output_name ^ "\"")
         |> replace_all
              ~pattern:("href=\"" ^ source_name ^ "#")
              ~with_:("href=\"" ^ output_name ^ "#")
       )
       html

let markdown_body pages markdown =
  let rec render_blocks acc blocks =
    match blocks with
    | Omd.Code_block (_, label, code) :: rest -> (
        match rest with
        | Omd.Code_block (_, label_next, code_next) :: remaining -> (
            match (syntax_of_label label, syntax_of_label label_next) with
            | Some Reason, Some Mlx ->
                render_blocks
                  (syntax_pair ~reason_label:label ~reason_code:code
                     ~mlx_label:label_next ~mlx_code:code_next ()
                  :: acc
                  )
                  remaining
            | Some Mlx, Some Reason ->
                render_blocks
                  (syntax_pair ~reason_label:label_next ~reason_code:code_next
                     ~mlx_label:label ~mlx_code:code ()
                  :: acc
                  )
                  remaining
            | _ ->
                render_blocks (code_figure ~label ~code () :: acc) rest
          )
        | _ ->
            render_blocks (code_figure ~label ~code () :: acc) rest
      )
    | block :: rest ->
        render_blocks (JSX.unsafe (Omd.to_html [ block ]) :: acc) rest
    | [] ->
        List.rev acc
  in
  markdown |> Omd.of_string |> render_blocks [] |> JSX.list |> JSX.render
  |> rewrite_html_links pages

